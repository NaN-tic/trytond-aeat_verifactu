#, python-format
msgctxt "model:ir.message,text:msg_delete_cancel"
msgid "Report \"%(report)s\" must be cancelled before deletion."
msgstr "El informe \"%(report)s\" debe cancelarse antes de su eliminación."

#, python-format
msgctxt "model:ir.message,text:msg_invoice_in_missing_ref"
msgid "The invoices \"%(invoices)s\" do not have reference."
msgstr "Las facturas \"%(invoices)s\" no tienen referencia."

#, python-format
msgctxt "model:ir.message,text:msg_invoices_verifactu"
msgid ""
"The following invoices are related to Verifactu books:\n"
"%(invoices)s.\n"
"\n"
"If you edit them be careful that information will NOT be sent to Verifactu again."
msgstr ""
"Las siguientes facturas están relacionadas con los libros de Verifactu: "
"%(facturas). Si las edita, tenga en cuenta que la información NO se volverá "
"a enviar a Verifactu."

msgctxt "model:ir.message,text:msg_invoices_verifactu_pending"
msgid "The following invoices are related to Verifactu books in draft state."
msgstr ""
"Las siguientes facturas están relacionadas con libros de Verifactu en estado"
" de borrador."

msgctxt "model:ir.message,text:msg_missing_certificate"
msgid ""
"There isn't a certificate defined in the account configuration for the "
"Verifactu."
msgstr ""
"No hay ningún certificado definido en la configuración de la cuenta para "
"Verifactu."

msgctxt "model:ir.message,text:msg_missing_fernet_key"
msgid "Missing Fernet key configuration"
msgstr "Falta la configuración de la clave Fernet"

#, python-format
msgctxt "model:ir.message,text:msg_missing_nif"
msgid "The party of invoice \"%(invoice)s\" must have a valid Tax Identifier."
msgstr ""
"El tercero que emite la factura \"%(invoice)s\" debe tener un identificador "
"fiscal válido."

msgctxt "model:ir.message,text:msg_missing_verifactu_journal"
msgid "There isn't a Verifactu journal defined in the account configuration."
msgstr ""
"No hay ningún diario de Verifactu definido en la configuración contable."

#, python-format
msgctxt "model:ir.message,text:msg_missing_verifactu_keys"
msgid ""
"The invoice \"%(invoice)s\" does not have the necessary Verifactu keys "
"filled."
msgstr ""
"La factura \"%(invoice)s\" no tiene las claves Verifactu necesarias "
"rellenadas."

#, python-format
msgctxt "model:ir.message,text:msg_missing_verifactu_party"
msgid ""
"Unable to resolve the party for downloaded Verifactu invoice \"%(invoice)s\""
" using NIF \"%(nif)s\"."
msgstr ""
"No se puede encontrar el tercero para la factura de Verifactu descargada "
"\"%(invoice)s\" usando NIF \"%(nif)s\"."

msgctxt "model:ir.message,text:msg_missing_verifactu_sync_company"
msgid "There is no company available to synchronize VeriFactu tax accounts."
msgstr ""
"No hay compañia disponible para sincronizar las cuentas de impuestos de "
"VeriFactu."

#, python-format
msgctxt "model:ir.message,text:msg_missing_verifactu_tax_account"
msgid "Tax \"%(tax)s\" has no Verifactu tax-account mapping configured."
msgstr ""
"El impuesto \"%(tax)s\" no tiene ninguna relación impuest-cuenta "
"configurado."

#, python-format
msgctxt "model:ir.message,text:msg_posted_invoices"
msgid ""
"Are you sure you want to change the Verifactu setting for period "
"\"%(period)s\"? Take into account that there are already posted invoices in "
"this period."
msgstr ""
"¿Está seguro de que desea cambiar la configuración de Verifactu para el "
"período \"%(period)s\"? Tenga en cuenta que ya hay facturas contabilizadas "
"en este período."

#, python-format
msgctxt "model:ir.message,text:msg_report_duplicated_invoice"
msgid "Invoice \"%(invoice)s\" is duplicated in Verifactu Report \"%(report)s\"."
msgstr ""
"La factura \"%(invoice)s\" está duplicada en el informe Verifactu "
"\"%(report)s\"."

#, python-format
msgctxt "model:ir.message,text:msg_report_wrong_invoice_state"
msgid "Invoice \"%(invoice)s\" must be posted, paid or refunded."
msgstr "La factura \"%(invoice)s\" debe ser registrada, pagada o reembolsada."

#, python-format
msgctxt "model:ir.message,text:msg_set_simplified_invoice"
msgid ""
"The parties of the invoices \"%(invoices)s\" have not set the Verifactu "
"Identifier as 'Simplified Invoice', but the invoice Verifactu operation key "
"is set as 'Simplified Invoice (ticket)' or 'Invoice summary entry'. The "
"invoices will be sent to AEAT without destination identification."
msgstr ""
"Las partes de las facturas «%(invoices)s» no han configurado el "
"identificador Verifactu como «Factura simplificada», pero la clave de "
"operación Verifactu de la factura está configurada como «Factura "
"simplificada (ticket)» o «Entrada de resumen de factura». Las facturas se "
"enviarán a AEAT sin identificación de destino."

#, python-format
msgctxt "model:ir.message,text:msg_set_simplified_party"
msgid ""
"The parties of the invoices \"%(invoices)s\" have the Verifactu Identifier "
"as 'Simplified Invoice'. The Verifactu operation key will be switched to "
"'Simplified Invoice (ticket)' or 'Invoice summary entry' as appropriate, and"
" the invoices will be sent to AEAT without destination identification."
msgstr ""
"Las partes de las facturas \"%(invoices)s\" tienen el identificador "
"Verifactu como \"Factura simplificada\". La clave de operación de Verifactu "
"se cambiará a \"Factura simplificada (ticket)\" o \"Entrada de resumen de "
"factura\", según corresponda, y las facturas se enviarán a AEAT sin "
"identificación de destino."

#, python-format
msgctxt "model:ir.message,text:msg_verifactu_matching_tax"
msgid ""
"Unable to resolve a unique Tryton tax for regime \"%(regime)s\", operation "
"\"%(operation)s\", exemption \"%(exemption)s\" and rate \"%(rate)s\"."
msgstr ""
"No se puede encontrar un impuesto Tryton único para el régimen "
"\"%(regimen)s\", operación \"%(operación)s\", exención \"%(exención)s\" y "
"tasa \"%(tasa)s\"."

#, python-format
msgctxt "model:ir.message,text:msg_verifactu_missing_surcharge_tax"
msgid "Tax \"%(tax)s\" has no equivalence surcharge related tax configured."
msgstr ""
"El impuesto \"%(tax)s\" no tiene configurado ningún recargo equivalente "
"relacionado con el impuesto."

msgctxt "model:ir.message,text:msg_verifactu_missing_tax_data"
msgid ""
"Downloaded Verifactu tax data has no usable fiscal criteria to resolve a "
"Tryton tax."
msgstr ""
"Los datos de impuesto descargados de Verifactu no contienen criterios "
"fiscales coincidentes para encontrar un impuesto de Tryton."

#, python-format
msgctxt "model:ir.message,text:msg_verifactu_operation_key_wrong"
msgid ""
"Invoice \"%(invoice)s\" has a wrong subject and operation Verifactu "
"combination."
msgstr ""
"La factura \"%(invoice)s\" tiene una combinación incorrecta de sujeto y "
"operación Verifactu."

msgctxt "model:ir.message,text:msg_verifactu_tax_account_unique"
msgid "Only one Verifactu tax-account mapping is allowed per company and tax."
msgstr ""
"Solo se permite una asignación de impuesto-cuenta de Verifactu por empresa y"
" por impuesto."

#, python-format
msgctxt "model:ir.message,text:msg_wrong_identifier_type"
msgid ""
"Party \"%(party)s\" of invoice \"%(invoice)s\" must have a valid Verifactu "
"Identifier \"VAT (only for intracommunity operators)\"."
msgstr ""
"El tercero \"%(party)s\" de la factura \"%(invoice)s\" debe tener un "
"identificador Verifactu válido \"IVA (solo para operadores "
"intracomunitarios)\"."

msgctxt "model:ir.message,text:reports_exist"
msgid ""
"There are some reports in draft and/or confirmed. No report will be created "
"until these reports will be processed."
msgstr ""
"Existen algunos informes en borrador y/o confirmados. No se generará ningún "
"informe hasta que se procesen estos informes."

